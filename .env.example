# --- Free APIs (use any one — priority: Groq > Gemini > Pollinations) ---

# Groq: best quality, free at https://console.groq.com (no credit card)
# 14,400 req/day free — Llama 3.1 70B
GROQ_API_KEY=

# Gemini: free at https://aistudio.google.com/app/apikey (key starts with AIza...)
# 1,500 req/day free
GEMINI_API_KEY=

# Pollinations.ai: zero config, no key needed — used automatically as last resort

# --- Paid fallbacks (optional) ---
# Only needed if you want to use GPT-4o / DALL-E instead of free alternatives
OPENAI_API_KEY=

# Only needed if you want Claude as a fallback when OpenAI is rate-limited
ANTHROPIC_API_KEY=

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_ORG_ID=your_org_id_if_posting_as_a_page

# --- Hermas / Hermes Agent (local dev only) ---
HERMAS_HERMES_URL=http://localhost:9119
HERMAS_PROFILE=default
