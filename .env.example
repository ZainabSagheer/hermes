# --- Free APIs (recommended) ---
# Get free Gemini key at: https://aistudio.google.com/app/apikey
# 1,500 requests/day free — no credit card needed
GEMINI_API_KEY=your_gemini_api_key_here

# --- Paid fallbacks (optional) ---
# Only needed if you want to use GPT-4o / DALL-E instead of free alternatives
OPENAI_API_KEY=

# Only needed if you want Claude as a fallback when OpenAI is rate-limited
ANTHROPIC_API_KEY=

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_ORG_ID=your_org_id_if_posting_as_a_page

# --- Hermas / Hermes Agent (local dev only) ---
HERMAS_HERMES_URL=http://localhost:9119
HERMAS_PROFILE=default
